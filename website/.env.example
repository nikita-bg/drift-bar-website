# Drift Bar Plovdiv — Environment Variables
# ⚠️ Копирай този файл като .env и попълни реалните стойности

# ── БАЗА ДАННИ ─────────────────────────────────────
# За локална разработка: използвай Neon или локален PostgreSQL
# Вземи безплатен PostgreSQL от: https://neon.tech
# Формат: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host/drift_bar?sslmode=require"

# ── BASE URL ───────────────────────────────────────
# Публичен URL на сайта (за sitemap, meta tags, etc.)
# Локално: http://localhost:3000
# Production: https://driftbarplovdiv.com
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ── n8n WEBHOOK ────────────────────────────────────
# URL на n8n webhook за нови поръчки (опционален)
N8N_WEBHOOK_URL=""

# ── TELEGRAM BOT (за n8n) ──────────────────────────
# Добави в Vercel Dashboard, НЕ тук
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""
