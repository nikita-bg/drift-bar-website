// ═══════════════════════════════════════════════
// Drift Bar Plovdiv — Database Schema
// SQLite for development, PostgreSQL for production
// ═══════════════════════════════════════════════

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── TABLES ────────────────────────────────────

model Table {
  id           String        @id @default(cuid())
  name         String        @unique
  capacity     Int
  location     String?
  active       Boolean       @default(true)
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// ─── RESERVATIONS ──────────────────────────────

model Reservation {
  id        String @id @default(cuid())
  date      String
  startTime String
  endTime   String
  duration  Int    @default(120)
  partySize Int

  guestName  String
  guestPhone String
  guestEmail String?
  notes      String?

  status  String @default("PENDING")
  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id])

  source    String   @default("website")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date, startTime])
  @@index([status])
}

// ─── EVENTS ────────────────────────────────────

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        String
  startTime   String
  endTime     String?
  category    String   @default("LIVE_MUSIC")
  image       String?
  entryPrice  Float?
  featured    Boolean  @default(false)
  status      String   @default("UPCOMING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([status])
}

// ─── BLOG POSTS ────────────────────────────────

model BlogPost {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  excerpt       String
  content       String
  featuredImage String?
  author        String   @default("Drift Bar Team")
  publishedAt   DateTime
  status        String   @default("DRAFT")
  tags          String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([slug])
  @@index([publishedAt])
  @@index([status])
}

// ─── ORDERS ────────────────────────────────────

model Order {
  id        String   @id @default(cuid())
  table     String
  items     String
  total     Float
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}
